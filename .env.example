# ─────────────────────────────────────────────────────────────────────────────
# PRism AI — Environment Variables
# Copy this file to backend/.env and fill in your keys.
# NEVER commit backend/.env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider Selection ────────────────────────────────────────────────────
# One of: openai | anthropic | gemini | groq | openrouter | azure | ollama
DEFAULT_LLM_PROVIDER=gemini

# ── LLM API Keys (only the key for your chosen provider is required) ──────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=                     # Used for Gemini
OPENROUTER_API_KEY=
GROQ_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=              # e.g. https://your-resource.openai.azure.com

# ── LLM Model Names (optional overrides) ─────────────────────────────────────
OPENAI_MODEL=gpt-4o
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
GEMINI_MODEL=gemini-1.5-pro
GROQ_MODEL=llama-3.3-70b-versatile

# ── LLM Behaviour ─────────────────────────────────────────────────────────────
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
LLM_TIMEOUT_SECS=120

# ── Embedding Provider ────────────────────────────────────────────────────────
# One of: sentence_transformers | openai | voyage | jina
# sentence_transformers works locally with no API key
DEFAULT_EMBEDDING_PROVIDER=sentence_transformers
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
ST_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Embedding API Keys (only required if not using sentence_transformers) ─────
VOYAGE_API_KEY=
JINA_API_KEY=

# ── Vector Database ───────────────────────────────────────────────────────────
# One of: qdrant | chroma | faiss
# faiss works in-process with no server — best for local dev
DEFAULT_VECTOR_DB=faiss
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ── GitHub Integration ────────────────────────────────────────────────────────
# Personal access token with repo:read scope (avoids rate limits)
GITHUB_TOKEN=
# For GitHub App webhook integration (optional)
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# ── Databases (optional — not required for core analysis) ────────────────────
POSTGRES_URL=postgresql+asyncpg://user:password@localhost:5432/prism
REDIS_URL=redis://localhost:6379

# ── Supabase (frontend — see frontend/.env.local.example) ─────────────────────
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Observability (optional) ──────────────────────────────────────────────────
LANGSMITH_API_KEY=
SENTRY_DSN=

# ── App Behaviour ─────────────────────────────────────────────────────────────
ENVIRONMENT=development             # development | production
DEBUG=false
LOG_LEVEL=INFO

# ── Analysis Tuning ───────────────────────────────────────────────────────────
MAX_DIFF_CHARS=60000                # Truncate diffs larger than this
MAX_FILES_PER_ANALYSIS=50
MAX_CHUNK_SIZE=1500                 # RAG chunk size in characters
CHUNK_OVERLAP=200
RETRIEVER_TOP_K=8                   # Number of RAG snippets per query

# ── Retry Policy ─────────────────────────────────────────────────────────────
RETRY_MAX_ATTEMPTS=3
RETRY_WAIT_MIN=1.0
RETRY_WAIT_MAX=30.0
