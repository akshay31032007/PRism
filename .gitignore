.ruff_cache/

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log

# ── Local databases ───────────────────────────────────────────────────────────
*.db
*.sqlite3

