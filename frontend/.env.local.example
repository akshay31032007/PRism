# ─────────────────────────────────────────────────────────────────────────────
# PRism Frontend — Environment Variables
# Copy this file to frontend/.env.local and fill in your keys.
# NEVER commit frontend/.env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# From: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── App URL (required for OAuth redirects in production) ──────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Backend API (used by /api/analyze proxy route) ────────────────────────────
BACKEND_URL=http://localhost:8000

# ── Legacy NextAuth (optional — only if still using next-auth routes) ───────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret-here
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
